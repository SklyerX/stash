{
  "name": "@skylerx/stash",
  "version": "1.0.0",
  "description": "A terminal-based encrypted link manager",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "stash": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "bun build src/index.ts --target node --format esm --outfile dist/index.js && chmod +x dist/index.js",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/cli-progress": "^3.11.6",
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "better-sqlite3-multiple-ciphers": "^12.9.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "figlet": "^1.11.0",
    "open": "^11.0.0",
    "rimraf": "^6.1.3",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "bookmarks",
    "cli",
    "links",
    "encrypted",
    "terminal"
  ],
  "license": "MIT"
}
